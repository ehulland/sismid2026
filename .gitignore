# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
venv/

# Secrets: never commit agent keys or tokens
.env
*.key
*_key
*.pem

# Agent secrets: ONLY the encrypted .enc blobs may be committed.
# Any plaintext that lands in secrets/ is ignored by default.
secrets/*
!secrets/*.enc
!secrets/README.md
# Google Trends key lives in its own subfolder (separate passcode, separate
# unlock script) so scripts/claude-login.sh does not try to decrypt it.
!secrets/gt-api/
secrets/gt-api/*
!secrets/gt-api/*.enc

# Codex broker: never commit real Codex credentials, claim state, or the passcode.
auth-*.json
server/creds/
state.json
broker.log
broker.out
passcode

# OS
.DS_Store

# Editor / interpreter scratch
*.pyc
.Rhistory
